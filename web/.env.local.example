# Copy to .env.local and fill in. .env.local is gitignored — NEVER commit a token.
#
# Fine-grained GitHub token with Issues: Read + Contents: Read on the repos below.
# The same token used by napps/govaj (it already covers both repos) works here.
# Server-side only — the MC dashboard reads issues; it never reaches the browser.
GITHUB_TOKEN=github_pat_xxxxxxxx

# Where bugs live (owner/name of a repo you control).
ZEROGUB_REPO=jumjum/zerogub-bugs

# Where feature requests live. Optional — falls back to ZEROGUB_REPO if unset.
ZEROGUB_FEATURES_REPO=jumjum/zerogub-features
